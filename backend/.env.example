DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mountainrun?schema=public"
PORT=4000
# Comma-separated browser origins (CORS + Clerk). Production example:
# FRONTEND_URL="https://mountainrun.in,https://www.mountainrun.in"
FRONTEND_URL="http://localhost:3000"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
RESEND_API_KEY=""
# Must be: email@domain.com  OR  Name <email@domain.com>
# Quote the whole value if it has spaces. Use a Resend-verified domain in production.
RESEND_FROM_EMAIL="Mountain Run <onboarding@resend.dev>"
# Auto email certificate when admin approves GPS proof (default true)
CERTIFICATE_AUTO_SEND="true"
# From https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
# Comma-separated emails always treated as admin
ADMIN_EMAILS="you@example.com"
# First signed-in user becomes SUPER_ADMIN if no admin exists (dev default true)
ADMIN_BOOTSTRAP="true"
